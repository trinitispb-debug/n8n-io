    {
      "parameters": {
        "jsCode": "// Обрабатываем полученные обновления от Telegram\nconst response = $input.first().json;\n\nif (!response.ok || !response.result || response.result.length === 0) {\n  return [];\n}\n\nconst updates = response.result;\nconst processedUpdates = [];\n\nfor (const update of updates) {\n  // Обновляем offset для следующего запроса\n  $workflow.lastOffset = update.update_id + 1;\n  \n  // Преобразуем формат обновления для совместимости с Telegram Trigger\n  if (update.message) {\n    processedUpdates.push({\n      update_id: update.update_id,\n      message: update.message\n    });\n  } else if (update.callback_query) {\n    processedUpdates.push({\n      update_id: update.update_id,\n      callback_query: update.callback_query\n    });\n  }\n}\n\nreturn processedUpdates;"
      },
      "id": "process-updates",
      "name": "Process Updates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
