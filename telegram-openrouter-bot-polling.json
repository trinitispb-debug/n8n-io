      "parameters": {
        "jsCode": "// Подготавливаем запрос к AI\nconst userMessage = $input.first().json.message.text;\nconst userId = $input.first().json.message.from.id;\nconst chatId = $input.first().json.message.chat.id;\n\n// Получаем сохраненную модель пользователя\nconst userModels = $workflow.userModels || {};\nconst selectedModel = userModels[userId] || 'openai/gpt-3.5-turbo';\n\nreturn {\n  userMessage: userMessage,\n  userId: userId,\n  chatId: chatId,\n  selectedModel: selectedModel\n};"
      },
