    {
      "parameters": {
        "jsCode": "// Обрабатываем ответ от OpenRouter API\nconst response = $input.first().json;\nconst chatId = $('Prepare AI Request').first().json.chatId;\nconst selectedModel = $('Prepare AI Request').first().json.selectedModel;\n\nlet aiResponse = '';\nlet errorMessage = '';\n\ntry {\n  if (response.choices && response.choices.length > 0) {\n    aiResponse = response.choices[0].message.content;\n  } else if (response.error) {\n    errorMessage = `❌ Ошибка API: ${response.error.message}`;\n  } else {\n    errorMessage = '❌ Неожиданный формат ответа от API';\n  }\n} catch (error) {\n  errorMessage = `❌ Ошибка обработки ответа: ${error.message}`;\n}\n\nreturn {\n  chatId: chatId,\n  aiResponse: aiResponse,\n  errorMessage: errorMessage,\n  selectedModel: selectedModel,\n  hasError: !!errorMessage\n};"
      },
