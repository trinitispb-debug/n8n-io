        "url": "=https://api.telegram.org/bot{{ $credentials.telegram.accessToken }}/getUpdates",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "offset",
              "value": "={{ $workflow.lastOffset || 0 }}"
            },
            {
              "name": "timeout",
              "value": "1"
            },
            {
              "name": "allowed_updates",
              "value": "=[\"message\", \"callback_query\"]"
            }
          ]
        },
        "options": {}
      },
      "id": "get-updates",
      "name": "Get Telegram Updates",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        460,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "telegram-credentials",
          "name": "Telegram Bot Credentials"
        }
      }
