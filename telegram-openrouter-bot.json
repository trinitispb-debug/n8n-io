    {
      "parameters": {
        "jsCode": "// Получаем сообщение пользователя\nconst userMessage = $input.first().json.message.text;\nconst userId = $input.first().json.message.from.id;\nconst chatId = $input.first().json.message.chat.id;\n\n// Здесь должна быть логика получения сохраненной модели пользователя\n// Для примера используем GPT-3.5 Turbo по умолчанию\nconst selectedModel = 'openai/gpt-3.5-turbo';\n\nreturn {\n  userMessage: userMessage,\n  userId: userId,\n  chatId: chatId,\n  selectedModel: selectedModel\n};"
      },
