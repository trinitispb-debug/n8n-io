    {
      "parameters": {
        "jsCode": "// Сохраняем выбранную модель в память пользователя\nconst callbackData = $input.first().json.callback_query.data;\nconst modelName = callbackData.replace('model_', '');\nconst userId = $input.first().json.callback_query.from.id;\nconst chatId = $input.first().json.callback_query.message.chat.id;\n\n// Словарь моделей с описаниями\nconst modelDescriptions = {\n  'openai/gpt-4-turbo': '🚀 GPT-4 Turbo - самая мощная модель OpenAI',\n  'openai/gpt-3.5-turbo': '⚡ GPT-3.5 Turbo - быстрая и эффективная модель',\n  'anthropic/claude-3.5-sonnet': '🎯 Claude 3.5 Sonnet - превосходная модель для анализа',\n  'anthropic/claude-3-haiku': '🧠 Claude 3 Haiku - быстрая модель Anthropic',\n  'meta-llama/llama-3.1-70b-instruct': '🔥 Llama 3.1 70B - мощная open-source модель',\n  'google/gemini-pro': '💎 Gemini Pro - продвинутая модель Google',\n  'openai/dall-e-3': '🎨 DALL-E 3 - генерация изображений от OpenAI',\n  'stability-ai/stable-diffusion-xl': '🖼️ Stable Diffusion XL - open-source генерация изображений'\n};\n\nreturn {\n  userId: userId,\n  chatId: chatId,\n  selectedModel: modelName,\n  modelDescription: modelDescriptions[modelName] || modelName,\n  callbackQueryId: $input.first().json.callback_query.id\n};"
      },
